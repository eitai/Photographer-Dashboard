# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/koral?sslmode=disable

# JWT — use a strong random secret (min 32 chars) in production
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL — used for CORS and gallery link emails
FRONTEND_URL=http://localhost:8080

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Light Studio" <your_email@gmail.com>

# Storage quota per admin (default 10 GB)
MAX_STORAGE_BYTES=10737418240


# ── S3 Object Storage ────────────────────────────────────────────────────────
# Leave blank to fall back to local disk (dev / self-hosted without S3 — only
# the legacy multer paths support this; the direct-upload pipeline requires
# all five S3_* / AWS_* values to be present at boot.)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com  # only for non-AWS providers
S3_PUBLIC_URL=https://your-bucket.s3.your-region.amazonaws.com
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ─────────────────────────────────────────────────────────────────────────────
# Compression worker (pg-boss). The API and the worker run as TWO separate
# processes against the same DATABASE_URL (`npm run workers`). The worker is
# OPTIONAL — without it, JPEG uploads still land on Wasabi but stay in
# format='original' (no JXL transcode). PNG sidecars are produced by the
# browser regardless of worker state.
# ─────────────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# Path to the vendored libjxl binaries used by the compression workers.
# Production: /usr/local/bin/photo-cjxl, /usr/local/bin/photo-djxl
# Development: leave default (must be in PATH)
PHOTO_CJXL_BIN=photo-cjxl
PHOTO_DJXL_BIN=photo-djxl

# Optional: assert binary version prefix at worker startup. Empty = skip check.
# Example: 0.11.
EXPECTED_CJXL_VERSION_PREFIX=
EXPECTED_DJXL_VERSION_PREFIX=
