# Face Recognition Service — Configuration
# Copy this file to .env and edit as needed.

# Host and port the service listens on.
# Use 127.0.0.1 to expose only to localhost (recommended when backend is on same machine).
# Use 0.0.0.0 to expose to the network.
HOST=127.0.0.1
PORT=8001

# Path where face embeddings are persisted between restarts.
# The directory is created automatically if it does not exist.
FACE_STORAGE_PATH=./data/embeddings.pkl
