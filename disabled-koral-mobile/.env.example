# =============================================================================
# Koral Mobile — Environment Variables
# =============================================================================
# Copy this file to .env in each app directory and fill in real values.
# NEVER commit .env files — they are listed in .gitignore.
#
# IMPORTANT — LAN IP vs localhost:
#   Physical iOS/Android devices cannot reach "localhost" on your dev machine.
#   localhost always resolves to the device itself.
#   You MUST use your machine's local network IP address (e.g. 192.168.1.42).
#
#   How to find your LAN IP:
#     Windows:  ipconfig          → look for "IPv4 Address" under your Wi-Fi adapter
#     macOS:    ipconfig getifaddr en0
#     Linux:    ip addr show
#
#   Both your dev machine and the device must be on the SAME Wi-Fi network.
# =============================================================================

# Base URL of the Express API server (koral-api, port 5000)
# Replace <LAN_IP> with your actual machine IP — e.g. http://192.168.1.42:5000
EXPO_PUBLIC_API_URL=http://<LAN_IP>:5000
