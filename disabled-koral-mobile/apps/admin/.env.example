# API base URL — must be your machine's LAN IP address, NOT localhost.
# "localhost" on a physical device refers to the device itself, not your computer.
#
# How to find your LAN IP:
#   Windows:  ipconfig  (look for "IPv4 Address" under your Wi-Fi adapter)
#   macOS:    ipconfig getifaddr en0
#   Linux:    ip addr show
#
# Your device and your development machine must be on the same Wi-Fi network.
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:5000
EXPO_PUBLIC_API_URL=http://192.168.X.X:5000

# Public photographer site URL (the React frontend URL, e.g. http://192.168.X.X:5173)
# Used to generate a shareable link to the photographer's public page.
# EXPO_PUBLIC_SITE_URL=http://192.168.X.X:5173
