{
  "cSpell.ignorePaths": [
    "FLOWS_HE.txt",
    "FLOWS_HE.md",
    "**/node_modules/**",
    "**/dist/**"
  ],
  "cSpell.enableFiletypes": [
    "!plaintext",
    "!markdown"
  ],
  "eslint.workingDirectories": [
    { "directory": "frontend", "changeProcessCWD": true },
    { "directory": "backend", "changeProcessCWD": true }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ]
}
